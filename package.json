{
  "name": "model-explorer",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "cli": "node --import tsx src/cli.ts",
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern eslint.config.mjs --ignore-pattern postcss.config.cjs --ignore-pattern tailwind.config.mjs --ignore-pattern vite.config.mjs --ignore-pattern vitest.config.mjs",
    "lint:check": "eslint . --ignore-pattern dist --ignore-pattern eslint.config.mjs --ignore-pattern postcss.config.cjs --ignore-pattern tailwind.config.mjs --ignore-pattern vite.config.mjs --ignore-pattern vitest.config.mjs --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "npm run format:check && npm run lint:check",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/x-data-grid": "^8.27.1",
    "@types/sparqljs": "^3.1.12",
    "@xyflow/react": "^12.8.5",
    "cmd-ts": "^0.15.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sparqljs": "^3.7.3"
  },
  "devDependencies": {
    "@acdh-oeaw/eslint-config": "^2.0.13",
    "@acdh-oeaw/tsconfig": "^1.5.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/unist": "^3.0.3",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.32.0",
    "postcss": "^8.4.49",
    "shiki": "^3.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "stylelint": {
    "extends": "@acdh-oeaw/stylelint-config"
  }
}
